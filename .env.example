# OPS-61 environment variables — copy to .env and fill in real values
# .env is gitignored. Never commit secrets.

# ============================================================
# LLM APIs
# ============================================================

# Claude Max API key (used by Loomless pipeline for first-line generation)
ANTHROPIC_API_KEY=

# Perplexity Pro API key (used by Loomless + JV pipelines for live research)
PERPLEXITY_API_KEY=

# ============================================================
# Google Workspace
# ============================================================

# Path to Service Account JSON file (read-only after creation)
# Service Account needs editor on the Sheet + write on the Drive folder
GOOGLE_SERVICE_ACCOUNT_PATH=./service-account.json

# Master CRM Sheet ID (from the Sheet's URL: docs.google.com/spreadsheets/d/<THIS_ID>/edit)
GOOGLE_SHEET_ID=

# Drive folder where Terminator Loom videos get uploaded
GOOGLE_DRIVE_FOLDER_ID=

# Drive folder where Loomless CSVs are dropped (watched by n8n)
GOOGLE_DRIVE_LOOMLESS_INBOX_FOLDER_ID=

# ============================================================
# n8n
# ============================================================

# n8n base URL (self-hosted on Hostinger VPS)
N8N_BASE_URL=https://n8n.fascinatecopy.com

# n8n webhook URL that the FB Group Chrome extension POSTs to
# Generated by n8n once the Inbound webhook node is configured
N8N_FB_ROUTER_WEBHOOK_URL=

# ============================================================
# Discord
# ============================================================

# Single feed channel for all OPS-61 pipeline notifications
# Thread per pipeline keeps signal high
DISCORD_WEBHOOK_OPS61_FEED=

# ============================================================
# Pipeline 3 — Terminator Loom Recorder
# ============================================================

# Local HTTP port for serving bundled ScreenFlow during recording
TERMINATOR_LOCAL_PORT=8765

# Path to master MP3 pitch (Jon's v0 setup task; placeholder OK for build)
TERMINATOR_MP3_PATH=./pipelines/03-terminator-loom/assets/master_pitch.mp3

# Path to profile pic overlay (PNG; or GIF if TERMINATOR_OVERLAY_FORMAT=gif)
TERMINATOR_OVERLAY_PATH=./pipelines/03-terminator-loom/assets/profile_overlay.png
TERMINATOR_OVERLAY_FORMAT=png  # png | gif

# Output directory for recorded videos before Drive upload
TERMINATOR_OUTPUT_DIR=./pipelines/03-terminator-loom/output

# ============================================================
# Pipeline 4 — FB Group Chrome extension
# ============================================================

# Set by extension config UI — group ID Rinoah/Jon manage
FB_GROUP_ID=
