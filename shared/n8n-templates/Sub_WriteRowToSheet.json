    {
      "parameters": {
        "jsCode": "// Auto-fill the per-tab timestamp column and flatten { tab, row } into a\n// single json object: { ...row, tab }. `tab` is kept ONLY for the Switch to\n// route on; the tab-specific Append nodes map columns explicitly (defineBelow)\n// and never write `tab`. Unknown tabs are NOT thrown here on purpose — they\n// fall through the Switch to the loud 'Unknown Tab' error branch.\nconst TIMESTAMP_COLUMN = {\n  Loomless: 'created_at',\n  JV_Targets: 'created_at',\n  Terminator_Loom: 'recorded_at',\n  Inbound: 'captured_at',\n};\n\nconst out = [];\nfor (const item of $input.all()) {\n  const data = item.json || {};\n  const tab = data.tab;\n  const row = { ...(data.row || {}) };\n  const tsCol = TIMESTAMP_COLUMN[tab];\n  if (tsCol && !row[tsCol]) {\n    row[tsCol] = new Date().toISOString().replace(/\\.\\d{3}Z$/, 'Z');\n  }\n  out.push({ json: { ...row, tab } });\n}\nreturn out;"
      },
      "id": "a1b2c3d4-0002-4000-8000-000000000002",
