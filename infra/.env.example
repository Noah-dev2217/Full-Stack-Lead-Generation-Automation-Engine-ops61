# OPS-61 infra secrets — TEMPLATE. Copy to infra/.env and fill in real values:
#   cp .env.example .env   (from inside infra/), then edit.
# infra/.env is gitignored; this template is committed.
#
# GOOGLE_SHEET_ID            — the OPS-61 CRM Google Sheet ID
#                             (docs.google.com/spreadsheets/d/<THIS_ID>/edit)
# DISCORD_WEBHOOK_OPS61_FEED — webhook URL for the #ops-61-feed channel.
#                             Dev currently points at the personal "OPS-61 Dev"
#                             server; swap for the prod webhook at cutover.
#
# --- Loomless pipeline (Build Spec #2) ---
# LOOMLESS_MODE         — mock | live. Dev default is `mock` (no real API calls,
#                         $0 cost). Flipping to `live` + real keys is the only
#                         change to go live (Build Spec #6). Ship default = mock.
# LOOMLESS_DEV_SHEET_ID — the dev CRM Sheet ID. In mock mode the workflow's
#                         fail-closed guard REFUSES to write unless
#                         GOOGLE_SHEET_ID == LOOMLESS_DEV_SHEET_ID. During dev,
#                         set this equal to GOOGLE_SHEET_ID.
# ANTHROPIC_API_KEY   — Claude Max API key. Used by the n8n "Anthropic account"
#                       credential and the Claude first-line call. Starts "sk-ant-".
#                       Only needed in live mode (Build Spec #6).
# PERPLEXITY_API_KEY  — Perplexity Pro API key. Read directly in the HTTP Request
#                       Authorization header (no dedicated credential).
#                       Only needed in live mode (Build Spec #6).
# LOOMLESS_BATCH_SIZE — max rows accepted from one CSV (guard). Default 100.
# LOOMLESS_DAILY_CAP  — max leads processed per day (guard). Default 100.

GOOGLE_SHEET_ID=
DISCORD_WEBHOOK_OPS61_FEED=
LOOMLESS_MODE=mock
LOOMLESS_DEV_SHEET_ID=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
LOOMLESS_BATCH_SIZE=100
LOOMLESS_DAILY_CAP=100
